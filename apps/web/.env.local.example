OPENAI_API_KEY=sk-your-openai-api-key-here

# Error reporting (optional) — get free API key at resend.com
RESEND_API_KEY=re_your_resend_api_key
ERROR_REPORT_EMAIL=your@email.com

# YouTube Data API v3 — get free key at console.cloud.google.com
# Enables auto-finding correct video IDs for non-English lessons
YOUTUBE_API_KEY=AIza_your_youtube_api_key

# Google AdSense — get publisher ID at adsense.google.com
# Format: ca-pub-XXXXXXXXXXXXXXXXX
# Leave empty to disable ads
NEXT_PUBLIC_ADSENSE_ID=

# ── PAYMENT GATEWAYS ──────────────────────────────────────────────────────────
# App URL (for redirect/webhook)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Supabase Service Role Key (for webhook to update user premium status)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# MoMo Payment (register at https://business.momo.vn)
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# Production: https://payment.momo.vn/v2/gateway/api/create

# ZaloPay (register at https://zalopay.vn/developer)
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
# Production: https://openapi.zalopay.vn/v2/create
